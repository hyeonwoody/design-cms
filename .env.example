# Copy to .env and fill in. Never commit .env.
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL connection for the design_cms database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/design_cms

# Base URL Wagtail uses to build absolute links in the admin
WAGTAILADMIN_BASE_URL=http://localhost:8000

# Figma import (Stage 04 feature). Token is a secret; keep it here only.
FIGMA_ACCESS_TOKEN=
FIGMA_FILE_KEY=
